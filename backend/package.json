{
  "name": "@deskclock/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate:up": "dotenv -e .env -- node-pg-migrate up --migrations-dir migrations --database-url-var DATABASE_URL",
    "migrate:down": "dotenv -e .env -- node-pg-migrate down --migrations-dir migrations --database-url-var DATABASE_URL",
    "migrate:test": "dotenv -e .env -- node-pg-migrate up --migrations-dir migrations --database-url-var DATABASE_URL_TEST",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.1.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.0.1",
    "jose": "^5.9.6",
    "postgres": "^3.4.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "dotenv-cli": "^11.0.0",
    "node-pg-migrate": "^7.9.1",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}